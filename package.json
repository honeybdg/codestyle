{
  "name": "@honeybdg/codestyle",
  "version": "1.0.7",
  "description": "Tooling and configuration for code style enforcement",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "license": "MIT",
  "homepage": "https://github.com/honeybdg/codestyle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honeybdg/codestyle.git"
  },
  "keywords": [
    "javascript",
    "nodejs",
    "rules",
    "style",
    "eslint"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src', 'lib', { recursive: true })\"",
    "lint": "npm run lint:eslint && npm run lint:stylelint",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint **/*.css"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.5.0",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
